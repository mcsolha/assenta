# Versões exatas, sem ^ ou ~ — defesa contra typosquatting/upgrades silenciosos
save-prefix=
save-exact=true

# Resolve peer deps automaticamente (caso contrário pnpm 10+ pode ser muito estrito p/ libs comuns)
auto-install-peers=true

# Verificação extra de integridade do conteúdo do store local
verify-store-integrity=true

# Forbid lockfile drift — se package.json e lockfile divergem, falhe
prefer-frozen-lockfile=true
