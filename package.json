{
  "name": "assenta",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Sistema de gestão de aluguel de cadeiras de evento",
  "scripts": {
    "dev": "vite",
    "routes:generate": "tsr generate",
    "typecheck": "tsr generate && tsc --noEmit",
    "build": "tsr generate && tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "audit": "pnpm audit --prod --audit-level=high",
    "audit:rust": "cargo audit --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-query": "5.100.11",
    "@tanstack/react-router": "1.170.4",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-opener": "2.5.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.2.1",
    "jazz-tools": "0.20.18",
    "lucide-react": "1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.0",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/router-cli": "1.167.5",
    "@tanstack/router-plugin": "1.168.6",
    "@tauri-apps/cli": "2.11.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.8.3",
    "vite": "7.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tauri-apps/cli",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.0"
}
